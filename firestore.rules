rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Rooms collection
    match /rooms/{roomId} {
      // Anyone can see a room to join it
      allow get: if true;
      // Host can create a room
      allow create: if request.resource.data.status == 'waiting'
                    && request.resource.data.createdAt == request.time;
      // Host can start/close session
      allow update: if request.resource.data.status in ['active', 'closed']
                    && request.resource.data.createdAt == resource.data.createdAt;
      
      // Participants sub-collection
      match /participants/{participantId} {
        // Hall view needs to see all participants
        allow read: if true;
        // Anyone can join a room
        allow create: if request.resource.data.status == 'waiting_for_ai';
        // AI background worker or matching logic updates these
        // In a real app, we'd use service account auth, but for demo we allow updates
        allow update: if true; 
      }
    }

    // Global Statistics
    match /global_stats/system {
      allow read: if true;
      // Transaction-based counter update
      allow update: if request.resource.data.activeRooms >= 0
                    && request.resource.data.activeRooms <= 50;
    }
    
    // Default: Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
